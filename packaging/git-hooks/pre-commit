#!/usr/bin/env bash
#
# sakimori pre-commit hook template.
#
# Refuses a commit when any staged lockfile would introduce dependencies
# younger than `MIN_AGE`. Unlike `sakimori deps watch`, which runs
# *after* the package manager writes the lockfile, this hook runs
# *before* the lockfile is recorded in git history — the last reliable
# chokepoint on desktop before CI.
#
# Install:
#   cp packaging/git-hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
# Or, to opt the whole team in:
#   git config core.hooksPath .githooks
#   mkdir -p .githooks && cp packaging/git-hooks/pre-commit .githooks/
#
# Customise:
set -eo pipefail

# How young is "too young". Accepts `7d`, `168h`, `600m`, `3600s`.
MIN_AGE="${SAKIMORI_MIN_AGE:-7d}"
# Patterns your team publishes itself and doesn't want blocked.
# Space-separated; quote if names contain spaces. Example:
#   IGNORE_PATTERNS='@my-org/* my-internal-*'
IGNORE_PATTERNS="${SAKIMORI_IGNORE_PATTERNS:-}"

# Which lockfile basenames we care about. Must match what `sakimori
# deps check` accepts.
LOCKFILE_NAMES=(
  package-lock.json
  Cargo.lock
  uv.lock
  poetry.lock
  requirements.txt
  packages.lock.json
)

# Only check lockfiles that are actually staged for this commit.
staged=()
for name in "${LOCKFILE_NAMES[@]}"; do
  while IFS= read -r -d '' f; do
    staged+=("$f")
  done < <(git diff --cached --name-only --diff-filter=ACMR -z -- "*/$name" "$name" 2>/dev/null || true)
done

if [[ ${#staged[@]} -eq 0 ]]; then
  exit 0
fi

echo "sakimori pre-commit: checking ${#staged[@]} lockfile(s) @ min-age=${MIN_AGE}"

if ! command -v sakimori >/dev/null 2>&1; then
  echo "sakimori: binary not found on PATH — install with brew / release tarball" >&2
  echo "(skipping the age check; commit proceeding)" >&2
  exit 0
fi

ignore_args=()
for pat in $IGNORE_PATTERNS; do
  ignore_args+=(--ignore "$pat")
done

if sakimori deps check --min-age "${MIN_AGE}" ${ignore_args[@]+"${ignore_args[@]}"} "${staged[@]}"; then
  exit 0
fi

cat >&2 <<EOF

────────────────────────────────────────────────────────────────
Commit refused: one or more staged lockfiles contain dependencies
younger than ${MIN_AGE}. Either:

  1. Pin an older in-range version in your manifest and re-run the
     install, or
  2. Wait, or
  3. Acknowledge deliberately by setting
         SAKIMORI_MIN_AGE=0 git commit …
     (bypasses this hook for one commit).
────────────────────────────────────────────────────────────────
EOF
exit 1
